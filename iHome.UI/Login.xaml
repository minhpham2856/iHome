<Window x:Class="iHome.UI.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:iHome.UI"
        mc:Ignorable="d"
        Title="Login" Height="400" Width="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo -->
        <Image Grid.Row="0" Source="Assets/Images/logo.png" 
               Height="100" Width="100" 
               HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Username -->
        <TextBlock Grid.Row="1" Text="Tên đăng nhập" 
                   FontWeight="SemiBold" FontSize="12"
                   Foreground="#000"
                   Margin="0,0,0,5"/>

        <TextBox Grid.Row="2" Name="txtUsername" 
                 Height="35" Margin="0,0,0,15"
                 FontSize="14" Padding="10,0,10,0"
                 BorderThickness="1.5"
                 BorderBrush="#DDD"
                 Background="#F9F9F9"
                 VerticalContentAlignment="Center"
                 KeyDown="txtUsername_KeyDown">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Foreground" Value="#000"/>
                    <Style.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#000"/>
                            <Setter Property="Background" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- Password -->
        <TextBlock Grid.Row="3" Text="Mật khẩu" 
                   FontWeight="SemiBold" FontSize="12"
                   Foreground="#000"
                   Margin="0,0,0,5"/>

        <PasswordBox Grid.Row="4" Name="txtPassword" 
                     Height="35" Margin="0,0,0,15"
                     FontSize="14" Padding="10,0,10,0"
                     BorderThickness="1.5"
                     BorderBrush="#DDDDDD"
                     Background="#F9F9F9" 
                     VerticalContentAlignment="Center"
                     KeyDown="txtPassword_KeyDown">
            <PasswordBox.Style>
                <Style TargetType="PasswordBox">
                    <Setter Property="Foreground" Value="#000"/>
                    <Style.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#000"/>
                            <Setter Property="Background" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </PasswordBox.Style>
        </PasswordBox>

        <!-- Forgot Password -->
        <TextBlock x:Name="tbForgotPassword" Grid.Row="5" Text="Quên mật khẩu?" 
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Foreground="#3498DB"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Cursor="Hand"
                   Margin="0,0,0,15"
                   MouseDown="tbForgotPassword_MouseDown">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#2980B9"/>
                            <Setter Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Login Button -->
        <Button Grid.Row="5" Name="btnLogin" 
                Content="ĐĂNG NHẬP"
                Height="40" 
                VerticalAlignment="Bottom"
                FontWeight="Bold" FontSize="14"
                Foreground="White"
                Background="#000"
                BorderThickness="0"
                Cursor="Hand"
                Click="btnLogin_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A252F"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#0F1A22"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
